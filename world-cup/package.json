{
  "name": "world-cup-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "FIFA World Cup 2026 dashboard — games, teams, players & stats (React + TypeScript + Vite)",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "ingest": "node scripts/ingest-espn.mjs",
    "ingest:friendlies": "node scripts/ingest-friendlies.mjs",
    "fetch-data": "node scripts/fetch-data.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.68.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
